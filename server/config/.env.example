# DOO 应用环境配置
# 复制本文件为 .env 并填入真实值
# cp .env.example .env

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=doo-app
DB_USER=root
DB_PASS=your_db_password_here

# API 配置
API_SECRET=your_secret_key_here
CORS_ORIGIN=http://localhost,capacitor://localhost,ionic://localhost,http://139.196.185.197:7070

# SMTP 邮件配置
SMTP_ENABLED=true
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_password_here
SMTP_FROM=your_email@qq.com
SMTP_FROM_NAME=DOO 应用

# 上传配置
UPLOAD_PATH=../uploads
UPLOAD_MAX_SIZE=5242880

# 日志配置
LOG_FILE=../logs/api.log
